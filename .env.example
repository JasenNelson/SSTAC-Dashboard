# Environment Variable Reference: see docs/ENVIRONMENT_REFERENCE.md for full
# semantics, defaults, and read-by file:line citations for every variable below.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local Engine Gating (optional — omit on Vercel, set in .env.local for local dev)
# Server-side: controls API route guards (runtime, not baked into client bundle)
LOCAL_ENGINE_ENABLED=true
# Client-side: controls UI conditional rendering (build-time inlined via NEXT_PUBLIC_)
NEXT_PUBLIC_LOCAL_ENGINE=true

# Regulatory Review Engine Paths (optional — override if engine repo is not at default location)
# Defaults to C:/Projects/Regulatory-Review/... if unset
# REG_REVIEW_ENGINE_BASE_PATH=C:/Projects/Regulatory-Review/engine
# Python interpreter for docling extraction (optional; defaults to 'python')
# Set this if your docling install is in a specific interpreter (e.g. Python 3.11)
# REG_REVIEW_PYTHON_PATH=C:/Users/your-user/AppData/Local/Programs/Python/Python311/python.exe

# Note: REG_REVIEW_EXTRACTIONS_PATH, REG_REVIEW_OUTPUT_PATH, and
# REG_REVIEW_TEMP_UPLOAD_PATH are not currently consumed by any code path
# (verified 2026-04-20). They are kept here as historical placeholders only.
# REG_REVIEW_EXTRACTIONS_PATH=...
# REG_REVIEW_OUTPUT_PATH=...
# REG_REVIEW_TEMP_UPLOAD_PATH=...

# HITL packet discovery (optional — defaults to a sibling-repo path under
# Regulatory-Review/1_Active_Reviews/Teck_Trail-WARP/2_Evaluation_Output)
# HITL_PACKET_DIR=C:/Projects/Regulatory-Review/1_Active_Reviews/Teck_Trail-WARP/2_Evaluation_Output

# Stale-status timeouts (optional, milliseconds; default 30 minutes)
# EVAL_STALE_TIMEOUT_MS=1800000
# EXTRACT_STALE_TIMEOUT_MS=1800000

# Ollama (optional — local model server)
# OLLAMA_BASE_URL is read by the model registry; OLLAMA_URL is forwarded to
# evaluation subprocesses when set. They are NOT interchangeable — see docs.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_URL=http://localhost:11434

# Upstash Redis (optional — distributed rate limiting; in-memory fallback when unset)
# REDIS_URL=https://your-instance.upstash.io
# REDIS_TOKEN=your-token

# Observability (optional)
# NEXT_PUBLIC_APP_VERSION is tagged on log entries; defaults to '1.0.0' when unset.
# NEXT_PUBLIC_APP_VERSION=1.0.0
# NEXT_PUBLIC_SENTRY_DSN enables browser Sentry; safe to be public per Sentry threat model.
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# Agentic OS embedded terminal modal (step 9 / Pattern E) -- LOCAL DEV ONLY.
# Required to enable the embedded xterm.js terminal modal on the admin
# Agentic OS page. The PTY sidecar (scripts/agentic-os-pty-server.mjs) WILL
# NOT START without this set, and the modal stays disabled in the UI
# regardless of the rest of the launch flow.
#
# Generate a fresh value with:  openssl rand -hex 32
# Or in PowerShell:              [Convert]::ToBase64String((1..32 | %{Get-Random -Maximum 256}))
#
# Never commit the real secret. NEVER prefix this with NEXT_PUBLIC_ -- it
# must remain server-side only.
# AGENTIC_OS_PTY_SECRET=replace-with-32-bytes-of-entropy
# AGENTIC_OS_PTY_PORT=3101
