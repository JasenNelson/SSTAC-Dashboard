# --- Agent-surface dirs EXCLUDED ENTIRELY ----------------------------------
# Same rationale as /.claude/ below: vendored skills, agent configs, and
# guardrail surfaces are never graph/wiki input.
/.agents/
/.codex/
/.gemini/
/.gstack/

# --- SUBSTRATE INVARIANT (fail-closed) --------------------------------------
# Enforced by graph_smoke.py at the Phase 2 first-build gate and by
# nightly_wiki_sync.ps1 steps N0/N4: the graph may contain only files that
# are GIT-TRACKED or on an explicit untracked-allowlist (default: empty).
# After every build, every source_file in graph.json must be in
# `git ls-files` or allowlisted; violations FAIL the run before wiki
# compile, listing offenders. Remediation is an ignore line added here
# (gated .graphifyignore commit -> config-hash full rebuild) or a file
# disposition decision. The named lines in this file are today's known
# offenders; the invariant catches tomorrow's.

# --- Docs trust (semantic-tier scope; see gen_docs_scope.py) ---------------
# gen_docs_scope.py additionally FAILS CLOSED on any .claude/, .agents/,
# .codex/, .gemini/, .gstack/, or *.pre-* path appearing in scan scope.
# CLAUDE.md-class guardrail docs are excluded from SEMANTIC extraction
# (guardrails are read from source, never re-derived from paraphrase).
/docs/archive/
*.pre-*
/*.md
/.claude/

# --- Phase-2-only extra line -------------------------------------------------
# SMOKE TEST ONLY (no LLM, no md wiki content this phase). Removed at
# Phase 4 with a mandatory from-scratch rebuild, when .graphifyignore
# switches from this blanket *.md line to the docs trust filter above.
*.md
# Full graphify DOC_EXTENSIONS blanket (gap-analysis finding 2, 2026-07-22):
# the code-only phase must exclude ALL doc extensions, not just .md. Removed
# together with the *.md line at Phase 4 (same mandatory from-scratch rebuild)
# when the docs-trust filter takes over.
*.mdx
*.qmd
*.txt
*.rst
*.html
*.yaml
*.yml

# --- Negation: keep README.md visible to the scan ---------------------------
# ORDERING MATTERS (gitignore last-match-wins): this line MUST be the LAST
# md-matching line in this file, placed AFTER both the docs-trust /*.md
# line above and the Phase-2-only blanket *.md line above -- otherwise the
# blanket re-excludes it and the probe fails for ordering, not support.
!/README.md

