{
  "name": "sstac-dashboard-temp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "pty-server": "node scripts/agentic-os-pty-server.mjs",
    "dev:all": "concurrently -k -n next,pty -c blue,magenta \"npm run dev\" \"npm run pty-server\"",
    "build": "next build",
    "build:monitored": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify/monitored-build.ps1",
    "build:monitored:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify/monitored-build.ps1 -CleanNext",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "cross-env CI=true vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "docs:gate": "node scripts/verify/docs-gate.mjs",
    "docs:gate:json": "node scripts/verify/docs-gate.mjs --json",
    "docs:archive:investigate": "node scripts/verify/docs-archive-investigation.mjs",
    "docs:archive:investigate:json": "node scripts/verify/docs-archive-investigation.mjs --json",
    "docs:archive:investigate:all": "node scripts/verify/docs-archive-investigation.mjs --root docs --root .github --include-root-md",
    "docs:archive:investigate:all:json": "node scripts/verify/docs-archive-investigation.mjs --root docs --root .github --include-root-md --json",
    "docs:manifest:update": "node scripts/verify/update-manifest-facts.mjs",
    "docs:manifest:update:vitest": "node scripts/verify/update-manifest-facts.mjs --vitest",
    "docs:manifest:update:playwright": "node scripts/verify/update-manifest-facts.mjs --playwright",
    "docs:manifest:update:k6": "node scripts/verify/update-manifest-facts.mjs --k6",
    "import:evaluation": "npx tsx scripts/import-evaluation-results.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@sentry/nextjs": "^10.22.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.54.0",
    "@upstash/redis": "^1.36.1",
    "@vercel/speed-insights": "^1.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.46",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.539.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.1.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tus-js-client": "^4.3.1",
    "ws": "^8.20.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20.19.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.6",
    "@vitest/ui": "^4.0.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.9",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.0"
  }
}
